               mPos.Y >= Keybind13.Position.Y and mPos.Y <= Keybind13.Position.Y + Keybind13.Size.Y then
                pcall(function() onKeyChanged() end)
                -- Keybind Click
                Keybind13_IsListening = true
                Keybind13_Text.Text = "..."
                Keybind13_Text.Color = Color3.fromHex("#FFFF00")
            end
        end

        -- Mouse Up (Just Released)
        if not mouse1 and lastMouse1 then
            dragging = nil
        end

        -- Dragging Update
        if dragging and mouse1 then
            local delta = mPos - dragStart
            dragging.Position = startPos + delta
        end

        lastMouse1 = mouse1
    end
end
